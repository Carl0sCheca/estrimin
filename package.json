{
  "name": "estrimin-web",
  "version": "3.1.0",
  "private": true,
  "target": "ES2017",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "test": "vitest",
    "generate": "pnpm prisma generate",
    "build": "next build",
    "start": "next start",
    "prod:start": "pnpm prisma migrate deploy && tsx src/scripts/startup.ts && next start",
    "lint": "eslint .",
    "startup": "tsx src/scripts/startup.ts",
    "buildandstart": "pnpm prisma generate && npx prisma migrate deploy && tsx src/scripts/startup.ts && next build && next start",
    "build:scheduler": "esbuild scheduler/src/index.ts --bundle --platform=node --format=esm --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --outfile=dist/scheduler/index.js --external:@prisma/client --external:zeromq --tsconfig=scheduler/tsconfig.json",
    "start:scheduler": "node ./dist/scheduler/index.js",
    "dev:scheduler": "tsx watch scheduler/src/index.ts",
    "buildandstart:scheduler": "pnpm build:scheduler && pnpm start:scheduler"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "^5.100.7",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "ffmpeg-stream": "^1.0.1",
    "mp4box": "^2.3.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "^5.6.0",
    "toad-scheduler": "^4.0.1",
    "uuid": "^14.0.0",
    "whep-player": "git://github.com/Carl0sCheca/whep-player-lib.git#fd34c0ab23a4a06b474f329cbc30ea81d96cd4e9",
    "zeromq": "^6.5.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "^2.10.25",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.13",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
